# Marketing site — build-time config (Vite). Copy to .env.local to override
# locally, or set these in the Vercel project settings. All values are public
# (Vite inlines VITE_* into the client bundle) — never put secrets here.

# The citizen web app that every "Open the app" / "Sign in" CTA opens.
# Leave unset in local dev to auto-detect the portal on localhost
# (marketing :5175 → portal :5173, or :3003 → :3000).
VITE_PORTAL_URL=https://oguaa-citizen.vercel.app

# Canonical/site URL of THIS marketing site, for SEO meta tags. Leave unset in
# dev to use the current serving origin.
VITE_SITE_URL=https://oguaa.vercel.app

# Backend API base (Render). Leave empty for same-origin/dev proxy.
VITE_API_URL=https://oguaa-api.onrender.com

# App store links (optional; default to "#").
VITE_IOS_URL=#
VITE_ANDROID_URL=#
