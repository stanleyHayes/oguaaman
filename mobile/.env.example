# Oguaa mobile app (Expo) — environment variables.
# Copy to .env.local for development, fill values in your EAS Build secrets for production.

# API origin — on a physical device set this to your machine's LAN IP.
# Production: https://api.oguaa.gh
EXPO_PUBLIC_API_URL=http://localhost:8080

# Cloudinary unsigned image upload (contribute form, gallery uploads).
# Create an UNSIGNED upload preset in your Cloudinary dashboard, then set:
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# Expo / EAS project config (eas.json / app.config.ts reference these).
# Get from expo.dev → your project.
EXPO_PROJECT_ID=
EXPO_PUBLIC_APP_ENV=development

# Google Maps API key (Android — for native MapView, if used).
# console.cloud.google.com → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Push notifications (Expo Push Service or FCM/APNs direct).
# Managed via EAS — no key needed in .env if using Expo's managed service.
# FCM Server Key (Android direct, optional):
# EXPO_PUBLIC_FCM_SERVER_KEY=
