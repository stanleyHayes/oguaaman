# Oguaa backend configuration. Copy to .env for local development.
# Full reference + where to get each key: ../KEYS.md
PORT=8080
GRPC_PORT=50051
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=oguaa

# CORS origin of the React frontend (Vite dev default). In prod: your portal URL.
ALLOWED_ORIGIN=http://localhost:5173

# Auth (spec §8.1, §9) — passwordless phone/email OTP → JWT sessions.
# JWT_SECRET: change for prod → `openssl rand -base64 48`.
JWT_SECRET=oguaa-dev-secret-change-me
OTP_TTL_MIN=10
# Set AUTH_REQUIRED=true in production: enforces real sign-in, closes the open
# dev back-office, and stops unauthenticated/mis-attributed writes.
AUTH_REQUIRED=false

# OTP delivery. "log" (dev — code shown on screen/logs) or "hubtel" (real SMS).
OTP_PROVIDER=log
# Required when OTP_PROVIDER=hubtel (get from the Hubtel dashboard → API):
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER_ID=Oguaa
# Optional override; defaults to Hubtel's send endpoint.
HUBTEL_SMS_ENDPOINT=

# Payments — adopt-a-project pledges via Paystack (spec §4/§6/§15).
# Without a secret key the pledge flow runs a clearly-labelled SIMULATION
# (no real money). Get keys at dashboard.paystack.com → Settings → API Keys.
PAYSTACK_SECRET_KEY=
# Public portal origin, used to build the Paystack callback URL.
PUBLIC_PORTAL_URL=http://localhost:5173
# Percentage of each confirmed pledge kept by the platform; the net is
# credited to the project. 5 = GH₵5 of every GH₵100.
PLATFORM_FEE_PERCENT=5

# First-party image uploads. Files are written here and served at /uploads/*.
UPLOAD_DIR=./uploads
# Public base URL prefixed onto returned image URLs. Empty = derive from the
# request (fine for local dev). In prod set to your API origin, e.g. https://api.oguaa.gh
PUBLIC_API_URL=

# AI writing assistant (spec §8.12). Optional: without a key the bar runs in a
# clearly-labelled simulation mode. The key is read server-side only.
# Usage is metered per UTC day in MongoDB (collection ai_usage) so caps survive
# restarts and hold across instances.
ANTHROPIC_API_KEY=
OGUAA_AI_MODEL=claude-haiku-4-5-20251001
OGUAA_AI_DAILY_BUDGET=60
OGUAA_AI_PER_MEMBER=20
