# Oguaa creator SPA — environment variables.
# Copy to .env.local for development, fill values in your deployment platform for production.

# Cloudinary unsigned image upload (institution editors, listing covers).
# Create an UNSIGNED upload preset in your Cloudinary dashboard, then set:
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# The community portal (citizen web app) that public-page / submit / join links
# open. Leave unset in dev to use the deployed default or your Vite proxy.
VITE_PORTAL_URL=https://citizen-oguaa.vercel.app

# API origin (defaults to same-origin /api via the Vite proxy in dev).
# Production: set to the backend service URL, e.g. https://oguaa-api.onrender.com
VITE_API_URL=https://oguaa-api.onrender.com
