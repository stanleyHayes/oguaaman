# Cloudinary unsigned image upload (contribute page).
# Create an UNSIGNED upload preset in your Cloudinary dashboard, then set:
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
# Optional: API origin (defaults to same-origin /api via the Vite proxy in dev)
# VITE_API_URL=
