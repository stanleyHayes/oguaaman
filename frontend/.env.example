# Oguaa portal (frontend) — environment variables.
# Copy to .env.local for development, fill values in your deployment platform for production.

# Cloudinary unsigned image upload (contribute / manage institution pages).
# 1. Create an account at cloudinary.com
# 2. Go to Settings → Upload → Upload Presets → Add upload preset → Unsigned
# 3. Copy the preset name and your cloud name below.
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# API origin (defaults to same-origin /api via the Vite proxy in dev).
# Production: set to the backend service URL, e.g. https://api.oguaa.gh
# VITE_API_URL=https://api.oguaa.gh
VITE_API_URL=

# Google Maps API key (optional — for enhanced directions links; omitting it
# falls back to the OpenStreetMap keyless embed which works fine).
# console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable: Maps JavaScript API, Maps Embed API, Places API.
VITE_GOOGLE_MAPS_API_KEY=

# Mapbox access token (optional alternative to Google Maps).
# account.mapbox.com → Access tokens
VITE_MAPBOX_TOKEN=

# Storefront shareable-link domain. Set to the owned apex (e.g. oguaaman.com)
# to make storefront links per-business subdomains
# (handle "neurodynecorp" → https://neurodynecorp.oguaaman.com). Blank → path
# form https://<citizen-app>/s/<handle> (used on *.vercel.app for now).
VITE_STOREFRONT_DOMAIN=
